# PostgreSQL (obligatorio en Vercel). Ejemplo con Neon:
# DATABASE_URL: URL con pooler (para la app en serverless)
# DIRECT_URL: URL directa (para migraciones de Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
